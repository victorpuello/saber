# =============================================================================
# Simulador Saber 11 — Variables de entorno (desarrollo)
# Copiar a .env y ajustar valores
# =============================================================================

# --- Conexión a Kampus ---
KAMPUS_BASE_URL=https://kampus.ieplayasdelviento.edu.co
KAMPUS_AUTH_ENDPOINT=/api/token/
KAMPUS_USERS_ENDPOINT=/api/users/
KAMPUS_STUDENTS_ENDPOINT=/api/students/
KAMPUS_TEACHERS_ENDPOINT=/api/teachers/

# --- JWT del simulador ---
JWT_SECRET=cambiar-en-produccion-usar-clave-segura-de-256-bits
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# --- Bases de datos ---
DB_PASSWORD=saber11_dev_password
POSTGRES_USER=saber11
POSTGRES_PASSWORD=saber11_dev_password

# --- Redis ---
REDIS_URL=redis://redis-saber11:6379/0

# --- API de IA ---
ANTHROPIC_API_KEY=sk-ant-XXXXXXX

# --- CORS ---
CORS_ORIGINS=http://localhost:5174

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT_MS=10000
VITE_FORGOT_PASSWORD_URL=/auth/forgot-password
VITE_KAMPUS_FORGOT_PASSWORD_URL=https://kampus.ieplayasdelviento.edu.co/
VITE_TERMS_URL=/legal/terms
VITE_PRIVACY_URL=/legal/privacy

# --- Kampus sync (Notification Service) ---
KAMPUS_API_TOKEN=
SYNC_INTERVAL_MINUTES=60

# --- Node ---
NODE_ENV=development
